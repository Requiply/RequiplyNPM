{
  "name": "@requiply/api-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for building equipment rental websites and apps with Requiply",
  "author": "Andrian Zafiiovskiy <andrian.zafiiovskiy@gmail.com>",
  "license": "MIT",
  "homepage": "https://requiply.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Requiply/RequiplyNPM.git",
    "directory": "packages/api-sdk"
  },
  "bugs": {
    "url": "https://github.com/Requiply/RequiplyNPM/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "requiply",
    "equipment rental",
    "construction rental",
    "event rental",
    "party rental",
    "sports rental",
    "outdoor rental",
    "rental",
    "inventory",
    "booking",
    "rental website",
    "rental booking",
    "sdk",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
